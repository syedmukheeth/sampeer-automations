# Trigger.dev - required by the Vercel server routes to trigger/poll task runs.
TRIGGER_SECRET_KEY=

# Google AI - required by the Trigger.dev worker for the invoice prose agent.
GOOGLE_GENERATIVE_AI_API_KEY=

# Resend - recommended production email provider.
# Set both values to send through Resend instead of Gmail.
RESEND_API_KEY=
RESEND_FROM=Sampeer Studio <finance@sampeerstudio.com>

# Composio Gmail - fallback email provider when Resend is not configured.
COMPOSIO_API_KEY=
COMPOSIO_USER_ID=
GMAIL_FROM=

# Two-role username/password auth (one shared signing secret).
# Generate AUTH_SECRET with: openssl rand -base64 48
AUTH_SECRET=
# Owner = founder/CEO. Full access, sees every detail.
AUTH_USERNAME=
AUTH_PASSWORD=
# Admin = operator. Can sign in + edit, but money values and Settings are hidden.
ADMIN_USERNAME=
ADMIN_PASSWORD=
# Optional (recommended): store scrypt hashes instead of plaintext passwords.
# Generate:  node scripts/hash-password.mjs '<password>'
# If *_HASH is set it wins over the plaintext *_PASSWORD above.
# AUTH_PASSWORD_HASH=
# ADMIN_PASSWORD_HASH=
