# Trigger.dev - required by the Vercel server routes to trigger/poll task runs.
TRIGGER_SECRET_KEY=

# Google AI - required by the Trigger.dev worker for the invoice prose agent.
GOOGLE_GENERATIVE_AI_API_KEY=

# Resend - recommended production email provider.
# Set both values to send through Resend instead of Gmail.
RESEND_API_KEY=
RESEND_FROM=Sampeer Studio <finance@sampeerstudio.com>

# Composio Gmail - fallback email provider when Resend is not configured.
COMPOSIO_API_KEY=
COMPOSIO_USER_ID=
GMAIL_FROM=

# Single-owner magic-link auth.
# Generate AUTH_SECRET with: openssl rand -base64 48
AUTH_SECRET=
OWNER_EMAIL=

# Optional public app URL for magic links. Defaults to the request origin locally.
APP_URL=
